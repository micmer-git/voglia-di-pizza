<!-- ═══════════════════════════════════════════
     WIZARD LOGIC
     ═══════════════════════════════════════════ -->
<script>
  const form = document.getElementById('wizardForm') as HTMLFormElement;
  const pages = document.querySelectorAll<HTMLElement>('.wizard-page');
  const dots = document.querySelectorAll<HTMLElement>('.wizard-step-dot');
  const bar = document.getElementById('wizardBar')!;
  const prevBtn = document.getElementById('wizardPrev')!;
  const nextBtn = document.getElementById('wizardNext')!;
  const submitBtn = document.getElementById('wizardSubmit')!;
  const successEl = document.getElementById('wizardSuccess')!;
  const reviewCard = document.getElementById('reviewCard')!;
  const totalSteps = pages.length;
  let current = 1;

  // Dynamic progress bar
  const barStyle = document.createElement('style');
  document.head.appendChild(barStyle);

  function updateBar() {
    const pct = (current / totalSteps) * 100;
    barStyle.textContent = `.wizard-progress-bar::after { width: ${pct}% !important; }`;
  }

  function goTo(step: number) {
    // Validate current page before moving forward
    if (step > current) {
      const currentPage = document.querySelector<HTMLElement>(`.wizard-page[data-page="${current}"]`);
      const requiredFields = currentPage?.querySelectorAll<HTMLInputElement>('[required]') || [];
      for (const field of requiredFields) {
        if (!field.value.trim()) {
          field.focus();
          field.classList.add('shake');
          setTimeout(() => field.classList.remove('shake'), 500);
          return;
        }
      }
    }

    current = step;
    pages.forEach(p => p.classList.remove('active'));
    document.querySelector(`.wizard-page[data-page="${current}"]`)?.classList.add('active');

    // Update dots
    dots.forEach(d => {
      const s = Number(d.dataset.step);
      d.classList.remove('active', 'done');
      if (s === current) d.classList.add('active');
      else if (s < current) d.classList.add('done');
    });

    updateBar();

    // Buttons
    prevBtn.style.display = current === 1 ? 'none' : '';
    nextBtn.style.display = current === totalSteps ? 'none' : '';
    submitBtn.style.display = current === totalSteps ? '' : 'none';

    // Build review on last step
    if (current === totalSteps) buildReview();
  }

  prevBtn.addEventListener('click', () => goTo(current - 1));
  nextBtn.addEventListener('click', () => goTo(current + 1));

  updateBar();

  function buildReview() {
    const val = (id: string) => {
      const el = document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement | null;
      return el?.value?.trim() || '—';
    };
    const fileInput = document.getElementById('menuFile') as HTMLInputElement;
    const fileName = fileInput.files?.[0]?.name || 'Nessun file caricato';
    const checkedStyle = document.querySelector<HTMLInputElement>('input[name="stile"]:checked');
    const styleName = checkedStyle?.value || 'Non selezionato';

    reviewCard.innerHTML = [
      ['Nome', val('nome')],
      ['Tagline', val('tagline')],
      ['Indirizzo', val('indirizzo')],
      ['Telefono', val('telefono')],
      ['WhatsApp', val('whatsapp')],
      ['Menu', fileName],
      ['Orari', val('orari')],
      ['Instagram', val('instagram')],
      ['Stile', styleName],
    ].map(([label, value]) =>
      `<div class="review-row"><span class="review-label">${label}</span><span class="review-value">${value}</span></div>`
    ).join('');
  }

  // File upload UX
  const menuUpload = document.getElementById('menuUpload')!;
  const menuFile = document.getElementById('menuFile') as HTMLInputElement;
  const menuFileName = document.getElementById('menuFileName')!;

  menuFile.addEventListener('change', () => {
    if (menuFile.files?.[0]) {
      menuFileName.textContent = `\u2713 ${menuFile.files[0].name}`;
      menuFileName.style.display = 'block';
    }
  });

  menuUpload.addEventListener('dragover', (e) => {
    e.preventDefault();
    menuUpload.classList.add('drag-over');
  });

  menuUpload.addEventListener('dragleave', () => {
    menuUpload.classList.remove('drag-over');
  });

  menuUpload.addEventListener('drop', (e) => {
    e.preventDefault();
    menuUpload.classList.remove('drag-over');
    if ((e as DragEvent).dataTransfer?.files?.[0]) {
      menuFile.files = (e as DragEvent).dataTransfer!.files;
      menuFileName.textContent = `\u2713 ${(e as DragEvent).dataTransfer!.files[0].name}`;
      menuFileName.style.display = 'block';
    }
  });

  // Submit
  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const emailField = document.getElementById('email') as HTMLInputElement;
    if (!emailField.value.trim()) {
      emailField.focus();
      return;
    }

    submitBtn.innerHTML = 'Invio in corso...';
    (submitBtn as HTMLButtonElement).disabled = true;

    const fd = new FormData(form);
    fd.append('_subject', `Nuova pizzeria: ${fd.get('nome')}`);
    fd.append('_captcha', 'false');
    fd.append('_template', 'box');

    try {
      const res = await fetch('https://formsubmit.co/ajax/michelemerelli.8@gmail.com', {
        method: 'POST',
        body: fd,
      });

      if (!res.ok) throw new Error('fail');

      form.style.display = 'none';
      document.querySelector('.wizard-progress')?.remove();
      document.querySelector('.wizard-nav')?.remove();
      successEl.style.display = 'block';
    } catch {
      // Fallback to mailto
      const fields = ['nome','tagline','indirizzo','telefono','whatsapp','orari','chiusura','consegna','instagram','facebook','stile','email','menuNote','note'];
      const body = fields.map(f => `${f}: ${fd.get(f) || '—'}`).join('\n');
      window.open(`mailto:michelemerelli.8@gmail.com?subject=${encodeURIComponent(`Nuova pizzeria: ${fd.get('nome')}`)}&body=${encodeURIComponent(body)}`);
      form.style.display = 'none';
      document.querySelector('.wizard-progress')?.remove();
      document.querySelector('.wizard-nav')?.remove();
      successEl.style.display = 'block';
    }
  });

  // Clicking style cards in the showcase pre-selects in wizard
  document.querySelectorAll('.style-card').forEach(card => {
    card.addEventListener('click', () => {
      const styleId = (card as HTMLElement).dataset.styleId;
      const radio = document.querySelector<HTMLInputElement>(`input[name="stile"][value="${styleId}"]`);
      if (radio) radio.checked = true;
      document.getElementById('inizia')?.scrollIntoView({ behavior: 'smooth' });
      setTimeout(() => { current = 3; goTo(4); }, 600);
    });
  });
</script>

</BaseLayout>
