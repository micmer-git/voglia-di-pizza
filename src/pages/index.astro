---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
import { STYLES } from '../data/styles';
---

<BaseLayout
  title="Voglia di Pizza — Il sito per la tua pizzeria"
  description="Sistema di ordinazione online per pizzerie. Menu digitale, ordini WhatsApp, dashboard. Pronto in 24 ore."
>

<form id="F" enctype="multipart/form-data">
<div class="track" id="track">

  <!-- 0 — HERO -->
  <div class="slide active" data-i="0">
    <div class="slide-inner" style="text-align:center; display:flex; flex-direction:column; align-items:center;">
      <p class="t-eyebrow reveal-text">Sistema ordini per pizzerie</p>
      <h1 class="t-hero reveal-text d1">Voglia<br/>di <em class="t-italic t-warm">Pizza</em></h1>
      <div class="gap-lg"></div>
      <p class="t-body reveal-text d2" style="text-align:center; max-width:38ch;">
        Il sito che la tua pizzeria merita.<br/>Menu, ordini WhatsApp, dashboard.<br/>Pronto domani.
      </p>
      <div class="gap-lg"></div>
      <button type="button" class="cta cta-dark reveal-text d3" onclick="go(1)">
        Inizia
        <svg width="18" height="18" fill="none" viewBox="0 0 20 20"><path d="M4 10h12m-4-4 4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
  </div>

  <!-- 1 — THE PROBLEM -->
  <div class="slide dark" data-i="1">
    <div class="slide-inner">
      <p class="t-eyebrow reveal-text">Il problema</p>
      <h2 class="t-big reveal-text d1" style="color:var(--bg);">
        Le app prendono<br/>fino al <em class="t-italic" style="color:var(--warm);">30%</em>
      </h2>
      <div class="gap-md"></div>
      <p class="t-body reveal-text d2">
        Deliveroo, Glovo, JustEat. Su una margherita da 7€, a te restano 4,90€. Su 3.000€ al mese, perdi 900€.
      </p>
      <div class="gap-sm"></div>
      <p class="t-body reveal-text d3">
        I clienti già ti scrivono su WhatsApp. Ma senza un menu digitale, ogni ordine è confusione.
      </p>
      <div class="gap-sm"></div>
      <p class="t-body reveal-text d4">
        Le agenzie chiedono 2.000–5.000€. Tu vuoi impastare, non gestire un sito.
      </p>
    </div>
  </div>

  <!-- 2 — THE SOLUTION -->
  <div class="slide" data-i="2">
    <div class="slide-inner">
      <p class="t-eyebrow reveal-text">La soluzione</p>
      <h2 class="t-big reveal-text d1">
        Tre passi,<br/><em class="t-italic t-warm">sei online</em>
      </h2>
      <div class="gap-lg"></div>
      <div class="reveal-text d2" style="display:flex;flex-direction:column;gap:1.2rem;">
        <div style="display:flex;gap:1rem;align-items:flex-start;">
          <span style="font-family:var(--serif);font-size:2rem;color:var(--fg-4);line-height:1;">1</span>
          <div><strong>Compila il form</strong><br/><span class="t-small">Nome, menu, colori. Cinque minuti.</span></div>
        </div>
        <div style="display:flex;gap:1rem;align-items:flex-start;">
          <span style="font-family:var(--serif);font-size:2rem;color:var(--fg-4);line-height:1;">2</span>
          <div><strong>Noi costruiamo</strong><br/><span class="t-small">Sito su misura con menu, ordini, dashboard.</span></div>
        </div>
        <div style="display:flex;gap:1rem;align-items:flex-start;">
          <span style="font-family:var(--serif);font-size:2rem;color:var(--fg-4);line-height:1;">3</span>
          <div><strong>Vai online</strong><br/><span class="t-small">In 24 ore. I clienti ordinano, tu incassi.</span></div>
        </div>
      </div>
    </div>
  </div>

  <!-- 3 — WHAT'S INCLUDED -->
  <div class="slide dark" data-i="3">
    <div class="slide-inner">
      <p class="t-eyebrow reveal-text">Tutto incluso</p>
      <h2 class="t-big reveal-text d1" style="color:var(--bg);">
        Non un sito.<br/><em class="t-italic" style="color:var(--warm);">Un sistema.</em>
      </h2>
      <div class="gap-lg"></div>
      <div class="reveal-text d2" style="display:grid;grid-template-columns:1fr 1fr;gap:1rem 2rem;">
        <div><span style="font-size:1.3rem;">📋</span> <strong style="color:var(--bg);">Menu digitale</strong><br/><span class="t-small" style="color:rgba(255,255,255,0.4);">Categorie, ricerca, aggiornabile.</span></div>
        <div><span style="font-size:1.3rem;">💬</span> <strong style="color:var(--bg);">Ordini WhatsApp</strong><br/><span class="t-small" style="color:rgba(255,255,255,0.4);">Formattati, zero confusione.</span></div>
        <div><span style="font-size:1.3rem;">🎙</span> <strong style="color:var(--bg);">Voce + AI</strong><br/><span class="t-small" style="color:rgba(255,255,255,0.4);">"Due margherite" — capisce.</span></div>
        <div><span style="font-size:1.3rem;">📊</span> <strong style="color:var(--bg);">Dashboard</strong><br/><span class="t-small" style="color:rgba(255,255,255,0.4);">Ordini, incassi, top pizze.</span></div>
        <div><span style="font-size:1.3rem;">🕐</span> <strong style="color:var(--bg);">Slot orari</strong><br/><span class="t-small" style="color:rgba(255,255,255,0.4);">Capacità forno gestita.</span></div>
        <div><span style="font-size:1.3rem;">🚗</span> <strong style="color:var(--bg);">Zone consegna</strong><br/><span class="t-small" style="color:rgba(255,255,255,0.4);">Prezzi per zona.</span></div>
      </div>
      <div class="gap-lg"></div>
      <a href="https://lulivo.pages.dev/menu/" target="_blank" class="cta cta-ghost reveal-text d3" style="color:var(--bg);border-color:rgba(255,255,255,0.3);">Vedi demo live</a>
    </div>
  </div>

  <!-- 4 — FORM: IDENTITY -->
  <div class="slide" data-i="4">
    <div class="slide-inner">
      <p class="t-eyebrow reveal-text">Passo 1 di 5</p>
      <h2 class="t-big reveal-text d1">
        Come si chiama<br/>la tua <em class="t-italic t-warm">pizzeria?</em>
      </h2>
      <div class="gap-lg"></div>
      <div class="reveal-text d2">
        <div class="field-row">
          <div class="field">
            <label class="field-label" for="nome">Nome *</label>
            <input class="field-input" id="nome" name="nome" placeholder="Pizzeria da Mario" required />
          </div>
          <div class="field">
            <label class="field-label" for="tagline">Tagline</label>
            <input class="field-input" id="tagline" name="tagline" placeholder="Napoletana d'Asporto" />
          </div>
        </div>
        <div class="field">
          <label class="field-label" for="indirizzo">Indirizzo *</label>
          <input class="field-input" id="indirizzo" name="indirizzo" placeholder="Via Roma 1, 24100 Bergamo" required />
        </div>
        <div class="field-row">
          <div class="field">
            <label class="field-label" for="telefono">Telefono *</label>
            <input class="field-input" type="tel" id="telefono" name="telefono" placeholder="035 123456" required />
          </div>
          <div class="field">
            <label class="field-label" for="whatsapp">WhatsApp *</label>
            <input class="field-input" type="tel" id="whatsapp" name="whatsapp" placeholder="348 1234567" required />
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- 5 — FORM: MENU -->
  <div class="slide dark" data-i="5">
    <div class="slide-inner">
      <p class="t-eyebrow reveal-text">Passo 2 di 5</p>
      <h2 class="t-big reveal-text d1" style="color:var(--bg);">
        Carica il tuo <em class="t-italic" style="color:var(--warm);">menu</em>
      </h2>
      <div class="gap-sm"></div>
      <p class="t-body reveal-text d2">In qualsiasi formato. Noi lo digitalizziamo.</p>
      <div class="gap-lg"></div>
      <div class="upload-zone reveal-text d3" id="uz" style="background:rgba(255,255,255,0.05);border-color:rgba(255,255,255,0.15);">
        <input type="file" id="menuFile" name="menu" accept=".pdf,.doc,.docx,.jpg,.jpeg,.png,.webp" />
        <div style="font-size:2rem;margin-bottom:0.3rem;">📄</div>
        <div style="font-weight:700;color:var(--bg);">Trascina o clicca</div>
        <div class="t-small" style="margin-top:0.2rem;color:rgba(255,255,255,0.35);">PDF, Word, immagine</div>
        <div id="fn" style="display:none;margin-top:0.5rem;color:var(--warm);font-weight:700;"></div>
      </div>
      <div class="gap-md"></div>
      <div class="field reveal-text d4">
        <label class="field-label" for="menuNote">Note</label>
        <textarea class="field-textarea" id="menuNote" name="menuNote" placeholder="Prezzi da aggiornare, piatti stagionali..." style="color:var(--bg);border-color:rgba(255,255,255,0.15);"></textarea>
      </div>
    </div>
  </div>

  <!-- 6 — FORM: HOURS -->
  <div class="slide" data-i="6">
    <div class="slide-inner">
      <p class="t-eyebrow reveal-text">Passo 3 di 5</p>
      <h2 class="t-big reveal-text d1">
        Quando apri e<br/>dove <em class="t-italic t-warm">consegni?</em>
      </h2>
      <div class="gap-lg"></div>
      <div class="reveal-text d2">
        <div class="field">
          <label class="field-label" for="orari">Orari *</label>
          <input class="field-input" id="orari" name="orari" placeholder="Lun–Dom 18:00–22:00 | Lunedì chiuso" required />
        </div>
        <div class="field-row">
          <div class="field">
            <label class="field-label" for="chiusura">Giorno chiusura</label>
            <select class="field-select" id="chiusura" name="chiusura">
              <option value="">Mai</option>
              <option value="1">Lunedì</option><option value="2">Martedì</option>
              <option value="3">Mercoledì</option><option value="4">Giovedì</option>
              <option value="5">Venerdì</option><option value="6">Sabato</option>
              <option value="0">Domenica</option>
            </select>
          </div>
          <div class="field">
            <label class="field-label" for="instagram">Instagram</label>
            <input class="field-input" id="instagram" name="instagram" placeholder="@pizzeriadamario" />
          </div>
        </div>
        <div class="field">
          <label class="field-label" for="consegna">Zone consegna</label>
          <textarea class="field-textarea" id="consegna" name="consegna" placeholder="Città: 1€ | Limitrofe: 2.50€"></textarea>
        </div>
      </div>
    </div>
  </div>

  <!-- 7 — FORM: STYLE -->
  <div class="slide dark" data-i="7">
    <div class="slide-inner">
      <p class="t-eyebrow reveal-text">Passo 4 di 5</p>
      <h2 class="t-big reveal-text d1" style="color:var(--bg);">
        Scegli lo <em class="t-italic" style="color:var(--warm);">stile</em>
      </h2>
      <div class="gap-sm"></div>
      <p class="t-body reveal-text d2">Il tema grafico del tuo sito.</p>
      <div class="gap-lg"></div>
      <div class="style-grid reveal-text d3">
        {STYLES.map((s) => (
          <label class="style-opt" style="background:rgba(255,255,255,0.05);border-color:rgba(255,255,255,0.12);">
            <input type="radio" name="stile" value={s.id} />
            <div class="style-dots">
              <span class="style-dot" style={`background:${s.primary}`}></span>
              <span class="style-dot" style={`background:${s.accent}`}></span>
            </div>
            <strong style="color:var(--bg);">{s.name}</strong>
            <span style="color:rgba(255,255,255,0.35);">{s.vibe}</span>
          </label>
        ))}
      </div>
    </div>
  </div>

  <!-- 8 — REVIEW + SUBMIT -->
  <div class="slide" data-i="8">
    <div class="slide-inner">
      <p class="t-eyebrow reveal-text">Passo 5 di 5</p>
      <h2 class="t-big reveal-text d1">
        Tutto <em class="t-italic t-warm">pronto?</em>
      </h2>
      <div class="gap-md"></div>
      <div class="review reveal-text d2" id="review"></div>
      <div class="gap-md"></div>
      <div class="reveal-text d3">
        <div class="field">
          <label class="field-label" for="email">La tua email *</label>
          <input class="field-input" type="email" id="email" name="email" placeholder="mario@pizzeria.it" required />
        </div>
        <div class="field">
          <label class="field-label" for="note">Note</label>
          <textarea class="field-textarea" id="note" name="note" placeholder="Qualsiasi dettaglio extra..."></textarea>
        </div>
      </div>
      <div class="gap-md"></div>
      <button type="submit" class="cta cta-warm reveal-text d4" id="sendBtn">
        Invia richiesta
        <svg width="16" height="16" fill="none" viewBox="0 0 20 20"><path d="M4 10h12m-4-4 4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
  </div>

  <!-- 9 — SUCCESS -->
  <div class="slide dark" data-i="9">
    <div class="slide-inner" style="text-align:center;display:flex;flex-direction:column;align-items:center;">
      <div class="success-check reveal-text">
        <svg width="28" height="28" fill="none" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </div>
      <h2 class="t-big reveal-text d1" style="color:var(--bg);">
        Richiesta<br/><em class="t-italic" style="color:var(--warm);">inviata</em>
      </h2>
      <div class="gap-md"></div>
      <p class="t-body reveal-text d2" style="text-align:center;">
        Riceverai il link al tuo nuovo sito<br/>entro 24 ore. Controlla la tua email.
      </p>
      <div class="gap-lg"></div>
      <p class="t-small reveal-text d3" style="color:rgba(255,255,255,0.35);">
        Voglia di Pizza &copy; 2026 —
        <a href="mailto:michelemerelli.8@gmail.com" style="color:rgba(255,255,255,0.5);">michelemerelli.8@gmail.com</a>
      </p>
    </div>
  </div>

</div>
</form>

<!-- NAV -->
<button class="nav-arrow nav-back" id="navBack" style="display:none;" type="button" aria-label="Indietro">
  <svg width="20" height="20" fill="none" viewBox="0 0 20 20"><path d="M4 10h12m-4-4 4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
</button>
<button class="nav-arrow" id="navNext" type="button" aria-label="Avanti">
  <svg width="20" height="20" fill="none" viewBox="0 0 20 20"><path d="M4 10h12m-4-4 4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
</button>
<div class="progress" id="prog"></div>
<div class="counter" id="counter">1 / 9</div>
<div class="key-hint" id="keyHint"><kbd>&larr;</kbd><kbd>&rarr;</kbd> per navigare</div>

<script is:inline>
  const track = document.getElementById('track');
  const slides = document.querySelectorAll('.slide');
  const prog = document.getElementById('prog');
  const counter = document.getElementById('counter');
  const navNext = document.getElementById('navNext');
  const navBack = document.getElementById('navBack');
  const keyHint = document.getElementById('keyHint');
  const TOTAL = slides.length;
  const LAST_STORY = 3; // slides 0-3 are story, 4+ are form
  const LAST_FORM = 8;  // slide 8 is submit
  let cur = 0;
  let submitted = false;

  function go(n) {
    if (n < 0 || n >= TOTAL) return;
    if (submitted && n < TOTAL - 1) return; // lock after submit
    // A/B tracking
    if (window.ABTesting) {
      window.ABTesting.trackSlide(n);
      if (n === LAST_FORM) window.ABTesting.trackFormComplete();
    }
    if (n > cur && n >= 4) {
      // validate required fields on current form slide
      const pg = slides[cur];
      const req = pg.querySelectorAll('[required]');
      for (const f of req) {
        if (!f.value.trim()) { f.focus(); return; }
      }
    }

    slides[cur].classList.remove('active');
    cur = n;
    slides[cur].classList.add('active');
    track.style.transform = 'translateX(-' + (cur * 100) + 'vw)';
    prog.style.width = ((cur + 1) / TOTAL * 100) + '%';
    counter.textContent = (cur + 1) + ' / ' + (TOTAL - (submitted ? 0 : 1));

    navBack.style.display = cur === 0 || submitted ? 'none' : '';
    navNext.style.display = cur >= LAST_FORM || submitted ? 'none' : '';
    navBack.classList.toggle('back', true);

    // Hide counter and hint on last slide
    counter.style.display = cur === TOTAL - 1 ? 'none' : '';
    keyHint.style.display = cur === 0 || cur === TOTAL - 1 ? 'none' : '';

    // Build review on slide 8
    if (cur === 8) buildReview();
  }

  // Arrow clicks
  navNext.addEventListener('click', function() { go(cur + 1); });
  navBack.addEventListener('click', function() { go(cur - 1); });

  // Keyboard
  document.addEventListener('keydown', function(e) {
    if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.tagName === 'SELECT') {
      if (e.key === 'Enter' && e.target.tagName !== 'TEXTAREA') { e.preventDefault(); go(cur + 1); }
      return;
    }
    if (e.key === 'ArrowRight' || e.key === ' ') { e.preventDefault(); go(cur + 1); }
    if (e.key === 'ArrowLeft') { e.preventDefault(); go(cur - 1); }
  });

  // Touch swipe
  let tx = 0;
  track.addEventListener('touchstart', function(e) { tx = e.touches[0].clientX; }, { passive: true });
  track.addEventListener('touchend', function(e) {
    const dx = e.changedTouches[0].clientX - tx;
    if (Math.abs(dx) > 50) { dx < 0 ? go(cur + 1) : go(cur - 1); }
  });

  // File upload
  const uz = document.getElementById('uz');
  const mf = document.getElementById('menuFile');
  const fn = document.getElementById('fn');
  mf.addEventListener('change', function() {
    if (mf.files && mf.files[0]) { fn.textContent = '\u2713 ' + mf.files[0].name; fn.style.display = 'block'; }
  });
  uz.addEventListener('dragover', function(e) { e.preventDefault(); uz.classList.add('over'); });
  uz.addEventListener('dragleave', function() { uz.classList.remove('over'); });
  uz.addEventListener('drop', function(e) {
    e.preventDefault(); uz.classList.remove('over');
    if (e.dataTransfer && e.dataTransfer.files[0]) {
      mf.files = e.dataTransfer.files;
      fn.textContent = '\u2713 ' + e.dataTransfer.files[0].name; fn.style.display = 'block';
    }
  });

  // Review
  function buildReview() {
    var v = function(id) { var el = document.getElementById(id); return el && el.value && el.value.trim() ? el.value.trim() : '\u2014'; };
    var fi = document.getElementById('menuFile');
    var file = fi.files && fi.files[0] ? fi.files[0].name : 'Nessun file';
    var checked = document.querySelector('input[name="stile"]:checked');
    var style = checked ? checked.value : '\u2014';
    var rows = [
      ['Nome', v('nome')], ['Tagline', v('tagline')], ['Indirizzo', v('indirizzo')],
      ['Telefono', v('telefono')], ['WhatsApp', v('whatsapp')], ['Menu', file],
      ['Orari', v('orari')], ['Instagram', v('instagram')], ['Stile', style]
    ];
    document.getElementById('review').innerHTML = rows.map(function(r) {
      return '<div class="review-row"><span class="review-l">' + r[0] + '</span><span class="review-v">' + r[1] + '</span></div>';
    }).join('');
  }

  // Submit
  document.getElementById('F').addEventListener('submit', async function(e) {
    e.preventDefault();
    var em = document.getElementById('email');
    if (!em.value.trim()) { em.focus(); return; }
    var btn = document.getElementById('sendBtn');
    btn.innerHTML = 'Invio...'; btn.disabled = true;
    var fd = new FormData(this);
    fd.append('_subject', 'Nuova pizzeria: ' + fd.get('nome'));
    fd.append('_captcha', 'false');
    fd.append('_template', 'box');
    try {
      var r = await fetch('https://formsubmit.co/ajax/michelemerelli.8@gmail.com', { method: 'POST', body: fd });
      if (!r.ok) throw 0;
    } catch (err) {
      var fields = ['nome','tagline','indirizzo','telefono','whatsapp','orari','chiusura','consegna','instagram','stile','email','menuNote','note'];
      var body = fields.map(function(f) { return f + ': ' + (fd.get(f) || '\u2014'); }).join('\n');
      window.open('mailto:michelemerelli.8@gmail.com?subject=' + encodeURIComponent('Nuova pizzeria: ' + fd.get('nome')) + '&body=' + encodeURIComponent(body));
    }
    submitted = true;
    go(9);
  });

  // Init
  go(0);
</script>

</BaseLayout>
